{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "A user's profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Generation": {
      "title": "Generation",
      "description": "A generated piece of content (image, video, or chat).",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the generation." },
        "userId": { "type": "string", "description": "The ID of the user who created this." },
        "type": { "type": "string", "enum": ["image", "video", "chat", "depth", "angle"], "description": "The type of content generated." },
        "prompt": { "type": "string", "description": "The prompt used to generate the content." },
        "resultUrl": { "type": "string", "format": "uri", "description": "The URL of the generated content (if applicable)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the generation was created." }
      },
      "required": ["id", "userId", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles."
    },
    "/generations/{generationId}": {
      "schema": { "$ref": "#/entities/Generation" },
      "description": "Stores generated content history."
    }
  }
}
